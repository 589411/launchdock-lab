{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Launchdock Lab projects",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "title", "type", "category", "level", "summary", "links", "status", "check", "added"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$", "maxLength": 40 },
      "title": { "type": "string", "minLength": 1, "maxLength": 30 },
      "type": { "enum": ["website", "gas-webapp", "gas-line", "notion-template", "llm-tool", "n8n-workflow", "repo", "other"] },
      "category": { "enum": ["自動化", "圖片", "寫作", "教學", "遊戲", "資料", "生活"] },
      "level": { "enum": [1, 2, 3] },
      "modules": {
        "type": "array",
        "items": { "type": "string", "pattern": "^M(0[1-9]|1[0-3])$" },
        "uniqueItems": true
      },
      "platforms": { "type": "array", "items": { "type": "string", "maxLength": 20 }, "maxItems": 6 },
      "summary": { "type": "string", "minLength": 1, "maxLength": 60 },
      "description": { "type": "string", "maxLength": 150 },
      "tomorrow": { "type": "string", "maxLength": 50 },
      "cover": { "type": "string", "pattern": "^[a-z0-9-]+\\.(png|jpg|jpeg|webp|svg)$" },
      "qr": { "type": "boolean" },
      "pinned": { "type": "boolean" },
      "links": {
        "type": "array",
        "minItems": 1,
        "maxItems": 4,
        "items": {
          "type": "object",
          "required": ["label", "url", "kind"],
          "additionalProperties": false,
          "properties": {
            "label": { "type": "string", "minLength": 1, "maxLength": 12 },
            "url": { "type": "string", "pattern": "^https://" },
            "kind": { "enum": ["open", "admin", "duplicate", "line-add", "repo", "video", "doc"] }
          }
        }
      },
      "status": { "enum": ["active", "archived", "broken"] },
      "check": { "enum": ["head", "none"] },
      "added": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
    }
  }
}
